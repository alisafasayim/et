# ============================================================
# Klinik Yönetim Sistemi — Çevre Değişkenleri
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env
# ============================================================

# --- Klinik Yerel Saat Dilimi ---
# Tüm randevu/ses kaydı eşleştirmeleri bu zone'a hizalanır.
CLINIC_TZ=Europe/Istanbul

# --- Google OAuth2 (Calendar + Forms) ---
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
# İki ayrı Google hesabı kullanılıyorsa (Forms bir hesapta, Calendar
# başka hesapta) her servis için ayrı token dosyası tanımlanabilir.
# Belirtilmezse GOOGLE_TOKEN_FILE'a düşer.
GOOGLE_CALENDAR_TOKEN_FILE=token_calendar.json
GOOGLE_FORMS_TOKEN_FILE=token_forms.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_ANAMNESIS_FORM_ID=1FAIpQLSxxx...

# --- Ses İşleme (Modül 1) ---
AUDIO_INBOX_DIR=./audio_inbox
WHISPER_MODEL_SIZE=large-v3
OLLAMA_MODEL=llama3
HF_TOKEN=hf_...
# Whisper öncesi WAV normalize + gürültü azaltma + sessizlik kırpma.
# pydub + ffmpeg sistem bağımlılığı gerektirir. Aşırı gürültülü
# saha kayıtlarında transkripsiyon kalitesini belirgin artırır.
AUDIO_PREPROCESS_ENABLED=false

# --- Notion (Modül 2) ---
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Extended schema modu (clinic_automation 5-DB yapısı):
#   false (varsayılan): clinic'in tek-DB yapısı; property isimleri
#                       "Hasta Adı", "Randevu Tarihi", "Randevu ID", "Durum".
#   true             : 5 ayrı DB (Hastalar, Konsültasyonlar, Ses Kayıtları,
#                       Form Yanıtları, Personel). Property isimleri
#                       "İsim", "Başlık", "Hasta" (relation), "Tarih", "Tanı".
# Aktif iken Sessions DB'siz veri yazılmaz; aşağıdaki ID'leri doldurun.
NOTION_EXTENDED_SCHEMA=false
NOTION_PATIENTS_DB_ID=
NOTION_SESSIONS_DB_ID=
NOTION_AUDIO_RECORDS_DB_ID=
NOTION_FORM_RESPONSES_DB_ID=
NOTION_STAFF_DB_ID=
# Hasta-seans hiyerarşisi:
#   false (varsayılan): her seans yeni DB satırı (eski davranış)
#   true              : hasta için tek kök, her seans kök sayfanın
#                       child page'i. DB'de yalnızca "Hasta Adı"
#                       (title) property'si zorunlu.
NOTION_HIERARCHICAL_MODE=false
# KVKK m.9 hibrit mod: aktifken Notion'a hasta adı/TCKN GÖNDERİLMEZ;
# pseudonym (#a4f9-c2b1) kullanılır. PII yalnızca yerel
# patient_registry.db'de (Türkiye'de) şifreli olarak tutulur.
# Aktivasyondan önce PII_ENCRYPTION_KEY ve PII_HASH_KEY mutlaka set
# edilmeli (yukarıda).
KVKK_HYBRID_MODE=false
# İlaç takibi için ayrı bir Notion DB. Boş bırakılırsa ilaç akışı no-op.
# DB schema: İlaç (title), Hasta (rich_text), Doz (rich_text),
#            Başlangıç (date), Bitiş (date), Durum (select), Notlar (rich_text)
NOTION_MEDICATIONS_DATABASE_ID=

# --- Evolution API / WhatsApp (Modül 3) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=evo_xxx
EVOLUTION_INSTANCE_NAME=clinic
GOOGLE_ANAMNESIS_FORM_URL=https://forms.gle/xxx
WEBHOOK_SECRET=rastgele_gizli_anahtar_buraya
WEBHOOK_PUBLIC_URL=https://yourdomain.com
WEBHOOK_LISTEN_PORT=5055
# Üretimde true (varsayılan) bırakın. Sadece dev ortamında imzasız
# istekleri kabul etmek için false yapın — açıkça bilinçli karar olmalı.
WEBHOOK_REQUIRE_SIGNATURE=true

# Payment webhook (POS/iyzico/Stripe gibi). Webhook'u
# /webhook/payment endpoint'ine yönlendirin; X-Webhook-Signature
# header'ında HMAC-SHA256(payload, PAYMENT_WEBHOOK_SECRET) bekler.
PAYMENT_WEBHOOK_SECRET=ayri_bir_gizli_anahtar
PAYMENT_JOB_POLL_INTERVAL_SEC=60
PAYMENT_JOB_STALE_SECONDS=1800
PAYMENT_JOB_POLL_LIMIT=5

# Admin paneli — set edilmezse /admin/* ve /ui/* endpoint'leri 404 döner.
# JSON API: Authorization: Bearer <token>
# Web UI:   /ui/login üzerinden bu token'la giriş yapılır
ADMIN_TOKEN=

# Admin web UI session imzası için Flask secret key (rastgele uzun string).
# Set edilmezse rastgele üretilir ama proses yeniden başladığında oturumlar
# geçersiz olur. Üretmek için:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=
ADMIN_LOGIN_MAX_FAILURES=5
ADMIN_LOGIN_LOCKOUT_SECONDS=900
DOCTOR_PHONE=905321234567

# Hasta WhatsApp ile "iptal" yazınca Calendar event'i otomatik sil.
# true yaparsanız OAuth scope yazılabilir (calendar.events) olur ve
# token.json silinerek kullanıcı yeniden onay vermek zorunda kalır.
CALENDAR_AUTO_DELETE_ON_CANCEL=false

# --- Paraşüt e-SMM (Modül 4) ---
PARASUT_CLIENT_ID=xxx
PARASUT_CLIENT_SECRET=xxx
PARASUT_USERNAME=doktor@klinik.com
PARASUT_PASSWORD=xxx
PARASUT_COMPANY_ID=12345
PARASUT_SMM_CATEGORY_ID=67890
JOB_POLL_INTERVAL_SEC=8
JOB_POLL_MAX_RETRIES=30

# Vergi oranları (% olarak, mali müşavirle teyit ZORUNLU)
# Türkiye'de psikiyatri muayenesi KDV'den muaftır (0); SMM'de gelir
# vergisi stopajı %20'dir (193 sayılı GVK m.94). KDV tevkifatı genelde 0.
VAT_RATE=0
WITHHOLDING_RATE=20
VAT_WITHHOLDING_RATE=0

# --- Ana Orkestratör ---
AUDIO_POLL_INTERVAL_SEC=60
CALENDAR_POLL_INTERVAL_SEC=600
# Calendar → Notion senkronizasyon cron'u (yeni randevuları Notion'a aktarır)
CALENDAR_SYNC_INTERVAL_SEC=1800
CALENDAR_SYNC_DAYS_AHEAD=14
# Yaklaşan randevu hatırlatma cron periyotları (saniye)
REMINDER_24H_INTERVAL_SEC=900
REMINDER_1H_INTERVAL_SEC=300
# Anamnez doldurmayan velilere takip mesajı (saatte bir önerilir)
ANAMNESIS_FOLLOWUP_INTERVAL_SEC=3600

# --- Calendar Watch (Push) ---
# true ise polling yerine push tabanlı bildirim. WEBHOOK_PUBLIC_URL
# HTTPS olmalı (Google bildirim için HTTPS gerektirir).
CALENDAR_PUSH_ENABLED=false
# Doğrulama token'ı; Google bildirim header'ında geri yollar.
# Boş bırakılırsa varsayılan olarak bildirimler fail-closed reddedilir.
CALENDAR_REQUIRE_PUSH_TOKEN=true
CALENDAR_PUSH_TOKEN=

# --- Loglama ---
CLINIC_LOG_FILE=./clinic.log
CLINIC_LOG_LEVEL=INFO
CLINIC_LOG_MAX_BYTES=10485760
CLINIC_LOG_BACKUP_COUNT=5

# --- State Store ---
CLINIC_STATE_DB=./clinic_state.db

# --- KVKK / PII Şifreleme (Faz 2) ---
# Türkiye'de tutulan hasta PII (TCKN, ad, telefon) için şifreleme.
# Notion'a bu veriler ASLA aktarılmaz; pseudonym (#a4f9-c2b1) kullanılır.
#
# Üretmek için:
#   python -c "from cryptography.fernet import Fernet; \
#              print(Fernet.generate_key().decode())"
# UYARI: Anahtar kaybolursa şifreli veriler ÇÖZÜLEMEZ. Yedek alın.
PII_ENCRYPTION_KEY=
# TCKN/ad araması için deterministik HMAC anahtarı (rastgele uzun string).
PII_HASH_KEY=
# Hasta kayıt veritabanı (Türkiye'de)
PATIENT_REGISTRY_DB=./patient_registry.db
# Audit log — KVKK m.12 erişim izi (append-only)
AUDIT_LOG_DB=./audit_log.db
