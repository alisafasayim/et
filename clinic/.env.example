# ============================================================
# Klinik Yönetim Sistemi — Çevre Değişkenleri
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env
# ============================================================

# --- Klinik Yerel Saat Dilimi ---
# Tüm randevu/ses kaydı eşleştirmeleri bu zone'a hizalanır.
CLINIC_TZ=Europe/Istanbul

# --- Google OAuth2 (Calendar + Forms) ---
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_ANAMNESIS_FORM_ID=1FAIpQLSxxx...

# --- Ses İşleme (Modül 1) ---
AUDIO_INBOX_DIR=./audio_inbox
WHISPER_MODEL_SIZE=large-v3
OLLAMA_MODEL=llama3
HF_TOKEN=hf_...

# --- Notion (Modül 2) ---
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Evolution API / WhatsApp (Modül 3) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=evo_xxx
EVOLUTION_INSTANCE_NAME=clinic
GOOGLE_ANAMNESIS_FORM_URL=https://forms.gle/xxx
WEBHOOK_SECRET=rastgele_gizli_anahtar_buraya
WEBHOOK_PUBLIC_URL=https://yourdomain.com
WEBHOOK_LISTEN_PORT=5055
# Üretimde true (varsayılan) bırakın. Sadece dev ortamında imzasız
# istekleri kabul etmek için false yapın — açıkça bilinçli karar olmalı.
WEBHOOK_REQUIRE_SIGNATURE=true
DOCTOR_PHONE=905321234567

# Hasta WhatsApp ile "iptal" yazınca Calendar event'i otomatik sil.
# true yaparsanız OAuth scope yazılabilir (calendar.events) olur ve
# token.json silinerek kullanıcı yeniden onay vermek zorunda kalır.
CALENDAR_AUTO_DELETE_ON_CANCEL=false

# --- Paraşüt e-SMM (Modül 4) ---
PARASUT_CLIENT_ID=xxx
PARASUT_CLIENT_SECRET=xxx
PARASUT_USERNAME=doktor@klinik.com
PARASUT_PASSWORD=xxx
PARASUT_COMPANY_ID=12345
PARASUT_SMM_CATEGORY_ID=67890
JOB_POLL_INTERVAL_SEC=8
JOB_POLL_MAX_RETRIES=30

# Vergi oranları (% olarak, mali müşavirle teyit ZORUNLU)
# Türkiye'de psikiyatri muayenesi KDV'den muaftır (0); SMM'de gelir
# vergisi stopajı %20'dir (193 sayılı GVK m.94). KDV tevkifatı genelde 0.
VAT_RATE=0
WITHHOLDING_RATE=20
VAT_WITHHOLDING_RATE=0

# --- Ana Orkestratör ---
AUDIO_POLL_INTERVAL_SEC=60
CALENDAR_POLL_INTERVAL_SEC=600
# Yaklaşan randevu hatırlatma cron periyotları (saniye)
REMINDER_24H_INTERVAL_SEC=900
REMINDER_1H_INTERVAL_SEC=300
# Anamnez doldurmayan velilere takip mesajı (saatte bir önerilir)
ANAMNESIS_FOLLOWUP_INTERVAL_SEC=3600

# --- Loglama ---
CLINIC_LOG_FILE=./clinic.log
CLINIC_LOG_LEVEL=INFO
CLINIC_LOG_MAX_BYTES=10485760
CLINIC_LOG_BACKUP_COUNT=5

# --- State Store ---
CLINIC_STATE_DB=./clinic_state.db
