# nginx reverse proxy şablonu — Klinik Yönetim Sistemi
#
# Kullanım:
#   1. Bu dosyayı /etc/nginx/sites-available/clinic'e kopyala
#   2. <CLINIC_DOMAIN> yerine kendi domain'ini yaz
#   3. sudo ln -s /etc/nginx/sites-available/clinic /etc/nginx/sites-enabled/
#   4. sudo nginx -t && sudo systemctl reload nginx
#   5. sudo certbot --nginx -d <CLINIC_DOMAIN>  (HTTPS sertifikası)
#
# Klinik webhook server 5055 portunda dinler. nginx 80→443 yönlendirme +
# Let's Encrypt + reverse proxy yapar.

# ---------------------------------------------------------------------------
# 80 → 443 yönlendirme
# ---------------------------------------------------------------------------
server {
    listen 80;
    listen [::]:80;
    server_name <CLINIC_DOMAIN>;

    # Let's Encrypt http-01 challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ---------------------------------------------------------------------------
# 443 (HTTPS) — reverse proxy
# ---------------------------------------------------------------------------
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name <CLINIC_DOMAIN>;

    # certbot sertifikaları (komut çalıştırıldıktan sonra otomatik gelir)
    ssl_certificate     /etc/letsencrypt/live/<CLINIC_DOMAIN>/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/<CLINIC_DOMAIN>/privkey.pem;

    # Modern TLS — Mozilla Intermediate
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    # HSTS — tarayıcı bir kez HTTPS'i öğrenince zorlar
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Diğer güvenlik header'ları (admin UI için)
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Body size — ses yükleme yapmıyoruz ama webhook payload'ları büyük olabilir
    client_max_body_size 10M;

    # ---------------------------------------------------------------------
    # Reverse proxy → Flask (5055)
    # ---------------------------------------------------------------------
    location / {
        proxy_pass http://127.0.0.1:5055;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Webhook'lar (Paraşüt async job, Calendar Watch) bazen yavaş
        proxy_connect_timeout 30s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # ---------------------------------------------------------------------
    # Admin UI rate-limit (login brute-force koruması)
    # nginx.conf http{} bloğunda tanımlanmalı:
    #   limit_req_zone $binary_remote_addr zone=admin_login:10m rate=5r/m;
    # ---------------------------------------------------------------------
    location = /ui/login {
        limit_req zone=admin_login burst=3 nodelay;
        proxy_pass http://127.0.0.1:5055;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Admin UI'yi opsiyonel olarak IP allowlist ile sınırla:
    # location /ui/ {
    #     allow 1.2.3.4;       # doktorun ofis IP'si
    #     allow 5.6.7.8;       # doktorun ev IP'si
    #     deny all;
    #     proxy_pass http://127.0.0.1:5055;
    # }
    # location /admin/ {
    #     allow 1.2.3.4;
    #     deny all;
    #     proxy_pass http://127.0.0.1:5055;
    # }

    # Access log — KVKK m.12 audit zaten uygulamada tutulur, burası
    # ek olarak hangi IP hangi endpoint'e basmış görünür.
    access_log /var/log/nginx/clinic-access.log;
    error_log  /var/log/nginx/clinic-error.log;
}
