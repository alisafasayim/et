# ===========================================
# Klinik Otomasyon Sistemi - Ortam Değişkenleri
# ===========================================
# Bu dosyayı .env olarak kopyalayıp doldurun:
#   cp .env.example .env

# --- Google API ---
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json
# Service Account kullanmak için (Gelişmiş Koruma aktifse gerekli):
GOOGLE_SERVICE_ACCOUNT_PATH=service_account.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_FORM_ID=
# Birden fazla form varsa virgülle ayırın (okul öncesi, okul sonrası, erişkin):
GOOGLE_FORM_IDS=

# --- Notion API (5 Veritabanı) ---
NOTION_API_KEY=
NOTION_PATIENTS_DB_ID=
NOTION_SESSIONS_DB_ID=
NOTION_AUDIO_RECORDS_DB_ID=
NOTION_FORM_RESPONSES_DB_ID=
NOTION_STAFF_DB_ID=

# --- WhatsApp (Twilio) ---
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# --- WhatsApp (Evolution API - alternatif) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# --- WhatsApp (360dialog - alternatif) ---
DIALOG360_API_KEY=
DIALOG360_CHANNEL_ID=

# --- WhatsApp Chatbot ---
CHATBOT_ENABLED=true
CHATBOT_CONFIDENCE_THRESHOLD=0.85
MESSAGING_HOURS_START=8
MESSAGING_HOURS_END=21

# --- Transkripsiyon ---
TRANSCRIPTION_PROVIDER=openai
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
WHISPER_LOCAL_MODEL=large-v3
AUDIO_DIR=./audio_files

# --- LLM (Klinik Not Üretimi) ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o

# --- Güvenlik (KVKK) ---
ENCRYPTION_KEY_PATH=.encryption_key
RSA_KEY_PATH=.rsa_key.pem
ENCRYPT_AUDIO=true
ENCRYPT_TRANSCRIPTS=true
FIELD_LEVEL_ENCRYPTION=true
AUDIT_LOG_PATH=audit.log
DATA_RETENTION_DAYS=2555
MEDICAL_RETENTION_YEARS=20
PATIENT_FILE_RETENTION_YEARS=15

# --- Genel ---
TIMEZONE=Europe/Istanbul
DEBUG=false
