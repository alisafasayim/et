# ===========================================
# Klinik Otomasyon Sistemi - Ortam Değişkenleri
# ===========================================
# Bu dosyayı .env olarak kopyalayıp doldurun:
#   cp .env.example .env

# --- Google API ---
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_FORM_ID=

# --- Notion API ---
NOTION_API_KEY=
NOTION_PATIENTS_DB_ID=
NOTION_SESSIONS_DB_ID=
NOTION_NOTES_DB_ID=

# --- WhatsApp (Twilio) ---
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# --- WhatsApp (Evolution API - alternatif) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# --- Transkripsiyon ---
TRANSCRIPTION_PROVIDER=openai
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
WHISPER_LOCAL_MODEL=large-v3
AUDIO_DIR=./audio_files

# --- LLM (Klinik Not Üretimi) ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o

# --- Güvenlik ---
ENCRYPTION_KEY_PATH=.encryption_key
ENCRYPT_AUDIO=true
ENCRYPT_TRANSCRIPTS=true
AUDIT_LOG_PATH=audit.log
DATA_RETENTION_DAYS=365

# --- Genel ---
TIMEZONE=Europe/Istanbul
DEBUG=false
